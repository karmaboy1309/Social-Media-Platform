# ========================================
# Social Media Platform - Environment Config
# ========================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/social_media_platform

# JWT Secret (change in production)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Upload Limits
MAX_FILE_SIZE=5242880
